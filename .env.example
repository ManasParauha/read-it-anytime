# Supabase Database Connections
# DATABASE_URL: Transaction pooled connection string (port 6543, with ?pgbouncer=true or similar if using PgBouncer)
DATABASE_URL="postgresql://postgres.[your-supabase-project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: Direct database connection string for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[your-supabase-project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase Auth Settings
NEXT_PUBLIC_SUPABASE_URL="https://[your-supabase-project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Google OAuth Credentials (for Supabase OAuth flow)
# Wire these in your Google Cloud Console and paste credentials in .env.local
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"


INNGEST_EVENT_KEY="your_inngest_signing_key_here"

# AI Provider Settings
AI_API_KEY="your_ai_api_key_here"

# Resend Email Settings
RESEND_API_KEY="re_your_api_key_here"

# Inngest Dev Mode
INNGEST_DEV=1

# Upstash Redis Settings (for rate limiting)
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token"

# Sentry Settings (for error tracking)
SENTRY_DSN="https://your-sentry-key.ingest.sentry.io/project-id"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-key.ingest.sentry.io/project-id"

SENTRY_AUTH_TOKEN=""